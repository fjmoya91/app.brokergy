# === Supabase (Postgres) — necesario siempre ===
# Supabase Dashboard > Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.okfeopwetlxdffrsbfqw.supabase.co:5432/postgres

# === Google Drive (opcional) — para subir los documentos automáticamente ===
# JSON completo de la Service Account (en una sola línea).
# La carpeta raíz de expedientes en Drive debe estar COMPARTIDA (editor) con el
# email del service account: xxxx@xxxx.iam.gserviceaccount.com
# Si se deja vacío, el endpoint devuelve los ficheros como ZIP descargable.
GOOGLE_SA_JSON=

# === Servidor ===
PORT=8080
