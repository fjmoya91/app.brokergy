# ================================================================
# BROKERGY — Backend Environment Variables
# Copiar este fichero como .env y rellenar todos los valores
# ================================================================

# ----- Servidor -----
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://app.brokergy.es

# ----- Supabase -----
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----- Google Drive OAuth2 -----
# Generar con: node scripts/drive_auth.js  (solo una vez o si caduca el token)
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx
GOOGLE_OAUTH_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Carpetas Google Drive -----
# DRIVE_ROOT_FOLDER_ID  = carpeta raíz ("PTE ENVIAR")
# DRIVE_TEMPLATE_ID     = carpeta plantilla que se clona al crear oportunidad
# Los demás corresponden a cada estado del ciclo de vida
DRIVE_ROOT_FOLDER_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DRIVE_TEMPLATE_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DRIVE_FOLDER_EN_CURSO=1sXDU-s-MqZ6EJSZnoMtAXJHcm_AIjL78
DRIVE_FOLDER_ENVIADA=1C4XSprT61mOgpW6LSNXwXefwuFRqudjn
DRIVE_FOLDER_ACEPTADA=1L2Wl9OIOpvmihySZkT09S1FG14Pu3VNy
# Carpeta "07. ENVIADOS A VERIFICAR": padre de las carpetas de cada lote
# (dentro se mueven los expedientes del lote + sus documentos al enviar al S.O.)
DRIVE_FOLDER_ENVIADOS_VERIFICAR=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Google Maps (geocoding backend) -----
# Restringir en Google Cloud Console a la IP del servidor Railway
GOOGLE_MAPS_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Generador RITE (microservicio Python) -----
# Servicio que genera la Memoria Técnica RITE (.docx) + Guía JE6 (.pdf).
# En producción (Docker Compose) lo inyecta docker-compose.yml como
# RITE_SERVICE_URL=http://rite-generator:8080 (red interna). En local, si no se
# define, el backend usa el valor por defecto http://localhost:8090
# (arrancar el servicio con: cd implementation/rite-generator && uvicorn server:app --port 8090).
RITE_SERVICE_URL=http://localhost:8090

# ----- Catastro (APIs públicas — los valores por defecto son correctos) -----
CATASTRO_API_URL=http://ovc.catastro.meh.es/ovcservweb/OVCSWLocalizacionRC/OVCCallejero.asmx
CATASTRO_COORD_API_URL=http://ovc.catastro.meh.es/ovcservweb/OVCSWLocalizacionRC/OVCCoordenadas.asmx

# ----- SMTP -----
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=465
SMTP_USER=usuario@tudominio.es
SMTP_PASS=REEMPLAZAR
SMTP_FROM="Tu Empresa" <usuario@tudominio.es>

# ----- Remitente del correo al Sujeto Obligado (lotes) — OPCIONAL -----
# El correo al S.O. puede salir desde otra dirección del mismo dominio. Si el
# proveedor SMTP no permite "enviar-como", hay que dar las credenciales propias de
# ese buzón aquí. Sin ellas, el correo del S.O. cae a la cuenta SMTP principal.
LOTE_SO_EMAIL_FROM=remitente-alternativo@tudominio.es
LOTE_SO_SMTP_USER=remitente-alternativo@tudominio.es
LOTE_SO_SMTP_PASS=REEMPLAZAR
# LOTE_SO_SMTP_HOST=smtp.tu-proveedor.com   # opcional (por defecto = SMTP_HOST)
# LOTE_SO_SMTP_PORT=465                      # opcional (por defecto = SMTP_PORT)

# ----- WhatsApp (whatsapp-web.js) — OPCIONAL -----
# WHATSAPP_ENABLED=true solo funciona en servidor persistente (VPS con Docker)
# La sesión vive en el volumen brokergy_whatsapp_auth y sobrevive a los deploys:
# el servicio se reconecta SOLO al arrancar. Solo hay que escanear el QR si
# WhatsApp invalida la sesión (dispositivo desvinculado, móvil >14 días offline).
WHATSAPP_ENABLED=false
WHATSAPP_CLIENT_ID=brokergy-main
WWA_MIN_DELAY_MS=2500
WWA_MAX_DELAY_MS=6000
WWA_TYPING_MS=1500
WWA_RATE_PER_MIN=10
WWA_MAX_RETRIES=5

# --- Supervisor de auto-conexión (watchdog) ---
# Reintenta la conexión sin intervención humana y avisa por email si es
# imposible. Ponlo a false en desarrollo local para que no relance Chrome.
WHATSAPP_AUTO_RECONNECT=true
WWA_WATCHDOG_MS=20000            # cada cuánto revisa el estado
WWA_INIT_TIMEOUT_MS=180000       # margen de arranque de Chrome antes de darlo por fallido
WWA_STUCK_MS=240000              # INITIALIZING/AUTHENTICATED más de esto = colgado → reset
WWA_ALERT_AFTER_FAILURES=6       # fallos seguidos antes de mandar el email de aviso

# Destinatario de las notificaciones admin (aceptaciones, cambios de estado)
# Puede ser un número de teléfono (ej: 34623926179) o el chatId de un grupo (ej: 120363XXXX@g.us)
# Para obtener el ID de un grupo: en el panel admin → WhatsApp → "Ver Grupos"
WHATSAPP_ADMIN_CHAT=34623926179

# Email del admin para alertas técnicas (rate-limit de Catastro, etc.).
# Si no se define, fallback a info@brokergy.es.
ADMIN_EMAIL=info@brokergy.es

# ----- Cloudflare Turnstile (anti-bot landing pública) — OPCIONAL en dev -----
# Mientras TURNSTILE_ENABLED=false la landing pública omite la verificación
# (útil para arrancar sin keys). En producción debe ser true.
# Generar keys en: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=0xXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# En frontend (Vite) hace falta también:
#   VITE_TURNSTILE_SITE_KEY=0xXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ----- OCR de CEE en "Nueva simulación" (solo ADMIN) -----
# Adaptador conmutable: gemini (por defecto) | openai
CEE_OCR_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Si CEE_OCR_PROVIDER=openai:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# ─── Avisos automáticos al admin ─────────────────────────────────────────────
# Tope duro entre avisos repetidos (por defecto 6 h). Un canal de alertas que
# puede repetirse agota la cuota del buzón (Hostinger: 100 correos/24 h) y deja
# a toda la app sin poder enviar. Incidente del 24/07/2026.
# En LOCAL conviene ponerlos a false: el portátil no tiene sesión de WhatsApp y
# comparte buzón con producción.
WWA_ALERT_EMAIL=true
WWA_ALERT_COOLDOWN_MS=21600000
CATASTRO_ALERT_EMAIL=true
CATASTRO_ALERT_COOLDOWN_MS=21600000
# Buzón por el que salen los avisos INTERNOS (WhatsApp caído, Catastro bloqueado).
# Por defecto usa el buzón secundario si existe, para no gastar la cuota del que
# escribe a clientes. Vacío = remitente normal.
ALERT_EMAIL_FROM=
