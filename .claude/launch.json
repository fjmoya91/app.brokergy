{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.js"],
      "cwd": "implementation/backend",
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--host"],
      "cwd": "implementation/frontend",
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "reforma-prototype",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "serve", "prototypes", "-l", "4321"],
      "port": 4321,
      "autoPort": true
    }
  ]
}
